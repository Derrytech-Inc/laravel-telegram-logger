{
    "name": "derrytech/telegram-logger",
    "description": "A self-configuring Laravel package for Telegram logging.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Derrick Azaglo",
            "email": "de.azaglo@gmail.com",
            "homepage": "https://github.com/de-azaglo/",
            "role": "Developer"
        },
        {
            "name": "Derrytech Team"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Derrytech\\TelegramLogger\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Derrytech\\TelegramLogger\\TelegramLoggingServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
